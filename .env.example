# No env vars are required for playback or an existing static catalog.
# Catalog refreshes prefer the YouTube Data API and fall back to yt-dlp.
# AI tagging runs only for newly discovered, untagged videos.
#
# Optional locally; configured as repository Actions secrets in production.
# YOUTUBE_API_KEY=
# FAGW_API_KEY=

# SaaS Maker widgets (feedback / changelog / testimonials)
NEXT_PUBLIC_SAASMAKER_API_KEY=

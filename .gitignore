# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# legacy Next.js output
/.next/
/out/

# production
/build
/dist/
/.astro/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
data/

# Cloudflare and legacy OpenNext build artifacts
.open-next/
.wrangler/

# fallow cache
.fallow/
cache.bin

# playwright
test-results/
playwright-report/

# Blume docs presentation layer (markdown in docs/ is the source of truth)
.blume/

# local agent logs / monitors
.ci-monitor.log
.ci-monitor.pid
*.agent.log
